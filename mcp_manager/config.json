{
    "server": {
        "host": "127.0.0.1",
        "port": 8765,
        "auto_start": true,
        "pid_file": "~/.web-proxy/server.pid",
        "log_file": "~/.web-proxy/server.log",
        "client_idle_timeout": 300
    },

    "browser_pool": {
        "max_browsers": 2,
        "max_tabs_per_browser": 5,
        "tab_idle_timeout": 300,
        "browser_idle_timeout": 1800,
        "enable_image_loading": false,
        "enable_font_loading": false,
        "lazy_browser_spawn": true
    },

    "tasks": {
        "thinking": {
            "adapter": "gemini",
            "description": "Deep reasoning and analysis via Google Gemini. Best for complex problem-solving, brainstorming, and multi-step logical thinking."
        }
    },

    "adapters": {
        "gemini": {
            "url": "https://gemini.google.com/app",
            "modes": [
                {
                    "name": "Fast",
                    "description": "Quick responses with lower latency. Best for simple questions and fast follow-ups."
                },
                {
                    "name": "Thinking",
                    "description": "Extended reasoning with chain-of-thought. Best for math, logic, and multi-step problems."
                },
                {
                    "name": "Pro",
                    "description": "Most capable model for complex tasks. Best for coding, analysis, and nuanced writing."
                }
            ],

            "login": {
                "url": "https://accounts.google.com",
                "profile_subdir": "gemini_login",
                "timeout": 300,
                "success_indicators": {
                    "titles": ["Google Account", "Google Accounts"],
                    "urls": [],
                    "selectors": []
                }
            },

            "selectors": {
                "input": {
                    "message-box": [
                        "[data-placeholder=\"Ask Gemini\"]",
                        "div[contenteditable=\"true\"]",
                        ".ql-editor"
                    ]
                },
                "output": {
                    "response-container": [
                        "message-content"
                    ],
                    "response-complete": [
                        "message-actions"
                    ]
                },
                "controls": {
                    "mode-picker": [
                        "[aria-label=\"Open mode picker\"]"
                    ],
                    "mode-item": [
                        "[mat-menu-item]"
                    ],
                    "temp-chat": [
                        "button[aria-label=\"Temporary chat\"]"
                    ]
                },
                "auth": {
                    "sign-in": [
                        "a[aria-label=\"Sign in\"]"
                    ]
                }
            }
        }
    }
}
